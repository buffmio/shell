{
  "archinstall-language": "English",
  "audio_config": {
    "audio": "pipewire"
  },
  "bootloader_config": {
    "bootloader": "grub",
    "uki": false,
    "removable": false
  },
  "debug": false,
  "hostname": "arch-kde",
  "kernels": [
    "linux"
  ],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "zh_CN.UTF-8"
  },
  "mirror_config": {
    "custom_servers": [
      {
        "url": "https://mirrors.ustc.edu.cn/archlinux/$repo/os/$arch"
      },
      {
        "url": "https://mirrors.tuna.tsinghua.edu.cn/archlinux/$repo/os/$arch"
      }
    ],
    "mirror_regions": {
      "China": []
    },
    "optional_repositories": [],
    "custom_repositories": []
  },
  "network_config": {
    "type": "nm"
  },
  "no_pkg_lookups": false,
  "ntp": true,
  "offline": false,
  "packages": [
    "alsa-utils",
    "ark",
    "bash-completion",
    "bluez-utils",
    "cups",
    "curl",
    "dolphin",
    "dolphin-plugins",
    "fcitx5-chinese-addons",
    "fcitx5-configtool",
    "fcitx5-im",
    "ffmpegthumbs",
    "filelight",
    "firefox",
    "fprintd",
    "fwupd",
    "git",
    "gwenview",
    "kate",
    "kcalc",
    "kdegraphics-thumbnailers",
    "kio-admin",
    "kio-extras",
    "konsole",
    "libreoffice-still",
    "libreoffice-still-zh-cn",
    "man-db",
    "man-pages",
    "nano",
    "noto-fonts",
    "noto-fonts-cjk",
    "noto-fonts-emoji",
    "okular",
    "partitionmanager",
    "power-profiles-daemon",
    "sddm-kcm",
    "ufw",
    "vim",
    "wget"
  ],
  "parallel downloads": 5,
  "profile_config": {
    "profile": {
      "main": "Desktop",
      "details": [
        "KDE Plasma"
      ],
      "custom_settings": {
        "KDE Plasma": {
          "plasma_flavor": "plasma-meta"
        }
      }
    },
    "gfx_driver": "AMD / ATI (open-source)",
    "greeter": "sddm"
  },
  "script": "guided",
  "silent": false,
  "swap": {
    "enabled": true,
    "algorithm": "zstd"
  },
  "timezone": "Asia/Shanghai"
}
